# ─────────────────────────────────────────────────────────────────────────────
# jmail environment configuration (copy to .env and fill in)
# ─────────────────────────────────────────────────────────────────────────────

# --- jmail-api (backend / BFF) ---
NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=4000
# Public origin of the web app, used for OIDC redirect + cookie settings.
PUBLIC_URL=http://localhost:5173
# Comma-separated allowed CORS origins for the SPA (dev).
CORS_ORIGINS=http://localhost:5173

# --- PostgreSQL (jmail app data) ---
DATABASE_URL=postgres://jmail:jmail@127.0.0.1:5432/jmail

# --- Sessions & secrets ---
# 32+ byte random strings. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-session-secret
# AES-256-GCM key (hex, 64 chars) used to encrypt OAuth refresh tokens at rest.
TOKEN_ENCRYPTION_KEY=change-me-64-hex-chars-aes-256-key

# --- OIDC provider (Keycloak recommended; passkeys + OAuth) ---
OIDC_ISSUER_URL=https://auth.example.com/realms/jmail
OIDC_CLIENT_ID=jmail
OIDC_CLIENT_SECRET=change-me
OIDC_REDIRECT_URI=http://localhost:4000/auth/callback
OIDC_SCOPES=openid profile email offline_access
# Also allow <PUBLIC_URL>/api/v1/mobile/callback in the OIDC client's redirect URIs.
# Claim used to derive admin status (role/group). Optional.
OIDC_ADMIN_CLAIM=jmail_admin

# --- Mail servers (existing infrastructure jmail connects to) ---
IMAP_HOST=mail.example.com
IMAP_PORT=993
IMAP_SECURE=true
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_SECURE=false

# --- jmail-agent (companion daemon on the mail host) ---
# Base URL the API uses to reach the agent.
AGENT_URL=https://mail.example.com:4100
# Shared bearer token (or use mTLS client certs below).
AGENT_TOKEN=change-me-agent-token
# Optional mTLS material (paths to PEM files).
# AGENT_CLIENT_CERT=/etc/jmail/agent-client.crt
# AGENT_CLIENT_KEY=/etc/jmail/agent-client.key
# AGENT_CA_CERT=/etc/jmail/agent-ca.crt

# ─────────────────────────────────────────────────────────────────────────────
# jmail-agent process (runs on the mail host) reads these:
# ─────────────────────────────────────────────────────────────────────────────
AGENT_HOST=0.0.0.0
AGENT_PORT=4100
# Must match AGENT_TOKEN above.
AGENT_SHARED_TOKEN=change-me-agent-token
# SpamAssassin paths on the mail host.
SA_GLOBAL_CONFIG=/etc/spamassassin/local.cf
SA_USER_PREFS_DIR=/var/lib/spamassassin
# Commands (override if wrapped in sudo).
SA_LEARN_CMD=sa-learn
SPAMASSASSIN_LINT_CMD=spamassassin --lint
SPAMD_RELOAD_CMD=systemctl reload spamassassin
